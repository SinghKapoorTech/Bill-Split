rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User's private data: only owner can write, but others can read basic profile info for search
    match /users/{userId} {
      // Allow any authenticated user to read profiles (needed for friends/squads)
      allow read: if request.auth != null;
      // Allow user to write only to their own profile, OR if they are creating/updating a shadow user
      allow create: if request.auth != null && (request.auth.uid == userId || request.resource.data.isShadow == true);
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        (resource.data.isShadow == true && request.resource.data.isShadow == true) ||
        // Allow any authenticated user to update only squadIds (for squad membership sync)
        onlyUpdating(['squadIds'])
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }



    // Events collection - users can read events they own or are members of
    match /events/{eventId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.ownerId ||
                      request.auth.uid in resource.data.memberIds ||
                      request.auth.token.email in resource.data.pendingInvites);
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.ownerId &&
                       request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.ownerId ||
                        // Allow members to update memberIds and pendingInvites (for auto-accept)
                        (request.auth.uid in resource.data.memberIds &&
                         onlyUpdating(['memberIds', 'pendingInvites', 'updatedAt'])) ||
                        // Allow invited users to accept their own invitation
                        (request.auth.token.email in resource.data.pendingInvites &&
                         onlyUpdating(['memberIds', 'pendingInvites', 'updatedAt'])));
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.ownerId;
    }

    // ========== Squads Collection ==========
    match /squads/{squadId} {
      // Any authenticated user can read squads they have the ID for.
      // Access control is enforced at app level via user.squadIds.
      allow read: if request.auth != null;
      
      allow create: if request.auth != null &&
                    request.auth.uid in request.resource.data.memberIds;
                    
      allow update: if request.auth != null &&
                    request.auth.uid in resource.data.memberIds;
                    
      allow delete: if request.auth != null &&
                    request.auth.uid in resource.data.memberIds;
    }

    // Helper function to check if only specific fields are being updated
    function onlyUpdating(allowedFields) {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(allowedFields);
    }

    // ========== Bills Collection Helper Functions ==========
    
    // Check if current user is in the bill's members array
    function isBillMember(billData) {
      return request.auth != null &&
             billData.members != null &&
             billData.members.hasAny([{'userId': request.auth.uid}]);
    }
    
    // Validate that only allowed fields are being updated (for guests)
    function isGuestUpdate() {
      let allowedFields = ['itemAssignments', 'people', 'lastActivity', 'updatedAt', 'members', 'splitEvenly', 'currentStep'];
      return onlyUpdating(allowedFields);
    }

    // ========== Bills Collection Security Rules ==========
    
    match /bills/{billId} {
      // Helper: Check if bill has a valid (non-expired) share code
      function hasValidShareCode() {
        return 'shareCode' in resource.data && resource.data.shareCode != null && 
               'shareCodeExpiresAt' in resource.data && resource.data.shareCodeExpiresAt != null &&
               resource.data.shareCodeExpiresAt > request.time;
      }

      function hasEventIdAndMember(data) {
        // Safe check for eventId existence and mapping
        let eId = 'eventId' in data ? data.eventId : ('eventId' in resource.data ? resource.data.eventId : null);
        let eventExists = exists(/databases/$(database)/documents/events/$(eId));
        return eId != null && eventExists && (
          request.auth.uid == get(/databases/$(database)/documents/events/$(eId)).data.ownerId ||
          ('memberIds' in get(/databases/$(database)/documents/events/$(eId)).data && 
           request.auth.uid in get(/databases/$(database)/documents/events/$(eId)).data.memberIds)
        );
      }

      // Helper: Check if user is a member of the squad attached to this bill
      function hasSquadIdAndMember(data) {
        let sId = 'squadId' in data ? data.squadId : null;
        return sId != null && 
          exists(/databases/$(database)/documents/squads/$(sId)) &&
          request.auth.uid in get(/databases/$(database)/documents/squads/$(sId)).data.memberIds;
      }


      // Helper: Only settlement-related fields are being changed.
      // processedBalances is written exclusively by the server-side pipeline.
      function isSettlementUpdate() {
        return onlyUpdating(['settledPersonIds', 'updatedAt', 'lastActivity']);
      }

      // Draft bills are readable only by their owner.
      // Bills missing a status field (legacy docs) evaluate null != 'draft' = true
      // in Firestore Rules, so they are treated as non-drafts and remain accessible.
      function isNotDraft() {
        return resource.data.status != 'draft';
      }

      // READ:
      // - Authenticated: Owner (including drafts), event members, squad members, linked participants, or bill members (non-drafts only)
      // - Anonymous: Bills with valid share code (non-drafts only)
      allow read: if
        // Anonymous users can read bills with valid share codes (non-draft only)
        (isNotDraft() && hasValidShareCode()) ||
        // Authenticated users follow normal rules
        (request.auth != null && (
          // Owner can always read, including their own drafts
          request.auth.uid == resource.data.ownerId ||
          // All non-owner paths: only non-draft bills are accessible
          (isNotDraft() && (
            // Linked participant via participantIds (null-safe for pre-migration bills)
            ('participantIds' in resource.data && request.auth.uid in resource.data.participantIds) ||
            // Event members can read event bills
            hasEventIdAndMember(resource.data) ||
            // Squad members can read squad bills
            hasSquadIdAndMember(resource.data) ||
            // Legacy: authenticated members can read (includes guests who joined via share link)
            isBillMember(resource.data)
          ))
        ));
      
      // CREATE: Authenticated users only, must set themselves as owner
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid &&
                       // For event bills, user must be a member of the event
                       (!('eventId' in request.resource.data) || 
                        request.resource.data.eventId == null ||
                        hasEventIdAndMember(request.resource.data));
      
      // UPDATE:
      // - Owner and event members have full access
      // - Authenticated members can update limited fields
      // - Anonymous users with valid share code can update limited fields (for claiming items)
      // - Linked participants can update settlement fields only (bidirectional settle-up)
      // NOTE: No draft gate on update — non-owner write paths are intentionally
      // ungated on status. Non-owners cannot discover a draft bill via read queries
      // (isNotDraft() blocks that), but anyone with a known bill ID can still write.
      allow update: if 
        // Anonymous users with valid share code can update assignments/people
        (hasValidShareCode() && isGuestUpdate()) ||
        // Authenticated users follow normal rules
        (request.auth != null && (
          // Owner has full access
          request.auth.uid == resource.data.ownerId ||
          // Event members have full access to event bills
          hasEventIdAndMember(resource.data) ||
          // Squad members have full access to squad bills
          hasSquadIdAndMember(resource.data) ||
          // Legacy: authenticated members can update specific fields
          (isBillMember(resource.data) && isGuestUpdate()) ||
          // Linked participant can perform guest updates (claim items, touch bill) or mark settlement
          ('participantIds' in resource.data &&
           request.auth.uid in resource.data.participantIds &&
           (isGuestUpdate() || isSettlementUpdate()))
        ));
      
      // DELETE: Only owner can delete
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.ownerId;
    }

    // ========== Friend Balances Collection ==========
    match /balances/{balanceId} {
      // allow get: handles both existing docs and non-existent docs.
      // resource == null is required so that runTransaction's transaction.get()
      // on a brand-new (not-yet-created) document doesn't throw a null-ref error.
      allow get: if request.auth != null &&
                    (resource == null || request.auth.uid in resource.data.participants);

      // allow list: handles getDocs() queries.
      // For queries, resource is never null, so we just check participants directly.
      // Firestore can verify this is safe because the query always filters by the
      // same uid: where('participants', 'array-contains', request.auth.uid).
      allow list: if request.auth != null &&
                     request.auth.uid in resource.data.participants;

      // Admin-only: server-side ledgerProcessor pipeline writes via Admin SDK
      allow create: if false;
      allow update: if false;

      allow delete: if false;
    }

    // ========== Event Balances Collection (per-pair, mirrors balances) ==========
    match /event_balances/{balanceId} {
      // allow get: handles both existing docs and non-existent docs (transaction reads)
      allow get: if request.auth != null &&
                    (resource == null || request.auth.uid in resource.data.participants);

      // allow list: for queries filtering by eventId
      // We allow reading if the user is a member of the event
      allow list: if request.auth != null &&
                     (
                       request.auth.uid in resource.data.participants ||
                       ('eventId' in resource.data && resource.data.eventId != null &&
                        exists(/databases/$(database)/documents/events/$(resource.data.eventId)) &&
                        (request.auth.uid == get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.ownerId ||
                         ('memberIds' in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data &&
                          request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.memberIds)))
                     );

      // Admin-only: server-side ledgerProcessor pipeline writes via Admin SDK
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ========== Settlements Collection ==========
    match /settlements/{settlementId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.fromUserId ||
                      request.auth.uid == resource.data.toUserId ||
                      ('eventId' in resource.data && resource.data.eventId != null &&
                       exists(/databases/$(database)/documents/events/$(resource.data.eventId)) &&
                       (request.auth.uid == get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.ownerId ||
                        ('memberIds' in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data &&
                         request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.memberIds))));
      
      allow create: if request.auth != null &&
                       (request.auth.uid == request.resource.data.fromUserId ||
                        request.auth.uid == request.resource.data.toUserId);
                        
      allow update: if false; // Settlements should be immutable
      
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.fromUserId ||
                        request.auth.uid == resource.data.toUserId);
    }

    // ========== Settlement Requests Collection ==========
    match /settlement_requests/{requestId} {
      // Get: allow for non-existent docs (needed for check-before-create pattern)
      allow get: if request.auth != null &&
                    (resource == null ||
                     request.auth.uid == resource.data.fromUserId ||
                     request.auth.uid == resource.data.toUserId);

      // List: only participants can query
      allow list: if request.auth != null &&
                     (request.auth.uid == resource.data.fromUserId ||
                      request.auth.uid == resource.data.toUserId);

      // Create: only the debtor (fromUserId), must be pending, amount > 0, not self-request
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.fromUserId &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.amount > 0 &&
                       request.resource.data.fromUserId != request.resource.data.toUserId &&
                       request.resource.data.createdAt == request.time &&
                       !('resolvedAt' in request.resource.data);

      // Update: only the creditor (toUserId), can only change status + resolvedAt
      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.toUserId &&
                       resource.data.status == 'pending' &&
                       (request.resource.data.status == 'approved' ||
                        request.resource.data.status == 'declined') &&
                       request.resource.data.resolvedAt == request.time &&
                       onlyUpdating(['status', 'resolvedAt']);

      // Delete: either participant (for cleanup)
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.fromUserId ||
                        request.auth.uid == resource.data.toUserId);
    }

    // Receipt analysis cache (locked down — re-enable when feature is re-added)
    match /receiptAnalysisCache/{document=**} {
      allow read, write: if false;
    }

    // Event invitations - users can read their own invitations
    match /eventInvitations/{invitationId} {
      allow read: if request.auth != null &&
                     (request.auth.token.email == resource.data.email ||
                      request.auth.uid == resource.data.invitedBy);
      allow write: if request.auth != null &&
                      request.auth.uid == resource.data.invitedBy;
      allow update: if request.auth != null &&
                       request.auth.token.email == resource.data.email;
    }

    // ========== Feedback Collection ==========
    match /feedback/{feedbackId} {
      // Create: authenticated users only, must set own userId
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      // No client reads/updates/deletes — admin console only
      allow read, update, delete: if false;
    }
  }
}
